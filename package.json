{
  "name": "safe-env",
  "version": "0.1.0",
  "description": "",
  "author": "Moody",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {
    "./dist/fs-node.js": "./dist/fs-browser.js",
    "./dist/fs-node.cjs": "./dist/fs-browser.js"
  },
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean",
