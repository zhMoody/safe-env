{
  "name": "@zh-moody/safe-env",
  "version": "0.3.4",
  "description": "Type-safe environment variables for Node.js and Browser with schema validation.",
  "author": "Moody",
  "license": "MIT",
  "homepage": "https://github.com/zhMoody/safe-env#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhMoody/safe-env.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/zhMoody/safe-env/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {
    "./dist/fs-node.js": "./dist/fs-browser.js",
    "./dist/fs-node.cjs": "./dist/fs-browser.js"
  },
  "scripts": {
    "dev": "tsup src/index.ts src/vite.ts src/fs-node.ts src/fs-browser.ts --watch",
    "build": "tsup src/index.ts src/vite.ts src/fs-node.ts src/fs-browser.ts --format cjs,esm --dts --minify --clean --splitting",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "keywords": [
    "env",
    "environment",
    "dotenv",
    "validation",
    "schema",
    "type-safe",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vite": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  }
}
